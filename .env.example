# ═══════════════════════════════════════════════════════════════
# SOLANA ARBITRAGE BOT — Required Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# PRIVATE KEY IS NOT IN THIS FILE.
# The wallet private key is provided at runtime via:
#   POST /api/wallet/connect { "privateKey": "base58..." }
# It lives in memory only — never written to disk, never logged.
# On server restart, you must call /api/wallet/connect again.

# ─── HELIUS (Required) ───────────────────────────────────────
# Get your API key at https://helius.dev (free tier works)
HELIUS_API_KEY=your_helius_api_key_here

# ─── JUPITER API KEYS (Required — 4 keys for round-robin) ───
# Create 4 free accounts at https://portal.jup.ag for rate limit headroom.
# Scanner uses these round-robin: 55 req/min per key = 220 req/min total.
JUPITER_API_KEY_1=your_jupiter_key_1
JUPITER_API_KEY_2=your_jupiter_key_2
JUPITER_API_KEY_3=your_jupiter_key_3
JUPITER_API_KEY_4=your_jupiter_key_4

# ─── CAPITAL ─────────────────────────────────────────────────
# Starting capital (auto-overridden by actual wallet balance on connect)
CAPITAL_SOL=10

# ─── AUTHENTICATION (Required) ───────────────────────────────
# Protects all API endpoints: /api/health, /api/metrics,
# /api/wallet/connect, /api/wallet/disconnect, etc.
ADMIN_TOKEN=your_secret_admin_token

# ─── SERVER ──────────────────────────────────────────────────
PORT=8080

# Set to true to start the bot automatically when the server starts.
# Bot will monitor prices but NOT trade until wallet is connected.
AUTO_START=false
