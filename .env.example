# ═══════════════════════════════════════════════════════════════
# SOLANA ARBITRAGE BOT — Required Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. NEVER commit .env to git.

# ─── HELIUS (Required) ───────────────────────────────────────
# Get your API key at https://helius.dev (free tier works)
HELIUS_API_KEY=your_helius_api_key_here

# ─── JUPITER API KEYS (Required — 4 keys for round-robin) ───
# Create 4 free accounts at https://portal.jup.ag for rate limit headroom.
# Scanner uses these round-robin: 55 req/min per key = 220 req/min total.
JUPITER_API_KEY_1=your_jupiter_key_1
JUPITER_API_KEY_2=your_jupiter_key_2
JUPITER_API_KEY_3=your_jupiter_key_3
JUPITER_API_KEY_4=your_jupiter_key_4

# ─── WALLET (Required) ───────────────────────────────────────
# Base58-encoded Solana private key. Loaded at startup.
# Alternative: leave blank and connect via POST /api/wallet/connect
PRIVATE_KEY=your_base58_private_key_here

# ─── CAPITAL ─────────────────────────────────────────────────
# Starting capital (auto-overridden by actual wallet balance at startup)
CAPITAL_SOL=10

# ─── AUTHENTICATION (Required) ───────────────────────────────
# Protects /api/health, /api/metrics, and admin endpoints.
ADMIN_TOKEN=your_secret_admin_token

# ─── SERVER ──────────────────────────────────────────────────
PORT=8080

# Set to true to start the bot automatically when the server starts.
# Set to false to start manually via POST /api/start.
AUTO_START=false
